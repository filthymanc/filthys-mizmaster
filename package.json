{
  "name": "filthys-mizmaster",
  "private": true,
  "version": "2.19.0",
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:start": "bash ../.agents/scripts/miz-dev.sh start",
    "dev:stop": "bash ../.agents/scripts/miz-dev.sh stop",
    "miz:browser": "bash ../.agents/scripts/miz-browser.sh",
    "miz:verify": "node ../.agents/scripts/miz-verify-pwa.cjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "prepare": "husky",
    "format": "prettier --write .",
    "release": "standard-version",
    "release:push": "npm run build && npm run release && git push --follow-tags origin main"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@headlessui/react": "^2.2.9",
    "idb": "^8.0.3",
    "prismjs": "^1.30.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.0.1",
    "react-virtuoso": "^4.18.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.2.0",
    "@commitlint/config-conventional": "^19.1.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "chrome-devtools-mcp": "^0.20.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "gh-pages": "^6.3.0",
    "husky": "^9.0.11",
    "postcss": "^8.4.38",
    "prettier": "^3.8.1",
    "standard-version": "^9.5.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^1.2.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "flatted": "3.4.2",
    "minimatch": "^10.2.1",
    "serialize-javascript": "^7.0.3"
  }
}
